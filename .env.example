# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git — it is already in .gitignore.

# ── Firebase ───────────────────────────────────────────────────────────────
# All Firebase vars use the VITE_ prefix so Vite exposes them to the browser.
# These values are semi-public (visible in built JS) — real security comes
# from Firestore rules and Firebase Auth, not from hiding these keys.

VITE_FIREBASE_API_KEY="your-api-key-here"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# ── Google Drive integration ──────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 client ID
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── Gemini AI (optional) ──────────────────────────────────────────────
# PREFERRED: Call Gemini from a Cloud Function / server endpoint that reads
# GEMINI_API_KEY from server-side process.env. The key never leaves the server.
#
# If you must call Gemini client-side, use the VITE_ prefix below so Vite
# only exposes it intentionally. Understand that VITE_ vars ARE visible in
# the built JavaScript bundle to anyone who inspects it.
#
# NEVER use a bare GEMINI_API_KEY (without VITE_) in a Vite project —
# the define pattern bypasses Vite's prefix safety and injects it anyway.
#
# VITE_GEMINI_API_KEY="your-gemini-api-key-here"
