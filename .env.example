# Copy this file to .env.local and fill in your values. Never commit .env.local to git.

# Firebase API Key, found in Firebase Console > Project Settings
VITE_FIREBASE_API_KEY="your-api-key-here"

# Firebase Auth Domain, found in Firebase Console > Project Settings (e.g., your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"

# Firebase Project ID, found in Firebase Console > Project Settings
VITE_FIREBASE_PROJECT_ID="your-project-id"

# Firebase Storage Bucket, found in Firebase Console > Project Settings (e.g., your-project-id.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# Firebase Messaging Sender ID, found in Firebase Console > Project Settings
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"

# Firebase App ID, found in Firebase Console > Project Settings
VITE_FIREBASE_APP_ID="your-app-id"

# Google Client ID for Google Drive integration, found in Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
