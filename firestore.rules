rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Platform-wide shared ────────────────────────────────────────────────

    match /shared_clients/{document=**} {
      allow read, write: if isAuthenticated();
    }

    match /platform_settings/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // ── Finance ─────────────────────────────────────────────────────────────

    match /projects/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /billingDocuments/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /payments/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /subscriptions/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /counterparties/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /products/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /legalEntities/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /budgetCategories/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /transactions/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /appSettings/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // ── CMS ─────────────────────────────────────────────────────────────────

    match /cms_contracts/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /cms_clients/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /cms_templates/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /cms_projects/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /cms_settings/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // ── Offers ──────────────────────────────────────────────────────────────
    // Offer documents embed sections and line_items as arrays.
    // workflow_log and notes live in subcollections (Phase 0, 2026-04-28).

    match /offers/{offerId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false; // soft-delete via status='archived' only

      // Workflow log — immutable audit trail.
      // Entries can be created but never modified or deleted.
      match /workflow_log/{entryId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if false;
      }

      // Notes — can be created and updated (e.g. pin toggle).
      // Deletion is disallowed to preserve the note history.
      match /notes/{noteId} {
        allow read, create, update: if isAuthenticated();
        allow delete: if false;
      }
    }

    match /offer_templates/{templateId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false; // archive only
    }

    // ── Default deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
